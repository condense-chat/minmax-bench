# minmax-bench configuration. Copy to `.env` and fill in what you need.
# Only the keys for the providers/strategies you actually run are required.

# --- Upstream provider keys (the proxies forward requests with these) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Direct-upstream base URLs (used by the "upstream" live-baseline strategy) ---
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Strategy proxy endpoints ---
# headroom: `pip install "headroom-ai[proxy]"` then `headroom proxy --port 8787`
HEADROOM_BASE_URL=http://127.0.0.1:8787

# condense (BOTH benches): api_url + caller creds are read from the local `dense`
# CLI config under ~/.config/dense (the same creds a real `dense` invocation uses),
# so there are no condense keys here — install the CLI and run `dense login`.
# CONDENSE_PROFILE picks which dense profile to use; leave blank to follow
# ~/.config/dense/target (prod default).
CONDENSE_PROFILE=

# --- Anthropic 1M-context beta header (sent on Anthropic proxy requests) ---
ANTHROPIC_BETA=context-1m-2025-08-07

# --- HuggingFace token for the gated SALT-NLP/SWE-chat dataset ---
# accept terms at https://huggingface.co/datasets/SALT-NLP/SWE-chat first
HF_TOKEN=

# --- Proxy output cap (Anthropic requires >= 1) ---
PROXY_MAX_TOKENS=1

# --- Headless-only condense fallback. Both benches authenticate condense via the
#     `dense` CLI login above; set this ONLY on a CI/no-CLI box that can't run
#     `dense login`. It is sent as `X-Condense-Auth-Token` (+ CONDENSE_USER_ID as
#     `X-Condense-User-Id`). Leave blank if you ran `dense login`. ---
CONDENSE_API_KEY=
CONDENSE_USER_ID=
